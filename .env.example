# ===========================================
# ScoreFlow — Variables d'environnement
# ===========================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Backend API
NEXT_PUBLIC_SCORING_API_URL=http://localhost:8000
SCORING_API_SECRET=your-scoring-api-secret

# Claude API (IA / extraction)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OCR
MISTRAL_API_KEY=your-mistral-key
# Fallback
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3

# Redis
REDIS_URL=redis://localhost:6379

# APIs publiques françaises
# (pas de clé requise pour la plupart)
INSEE_API_KEY=your-insee-key
# INPI : compte gratuit sur data.inpi.fr
INPI_USERNAME=
INPI_PASSWORD=

# Serper (recherche web)
SERPER_API_KEY=your-serper-key

# PDF Export
PUPPETEER_EXECUTABLE_PATH=

# Sécurité
JWT_SECRET=your-jwt-secret-for-share-links
RATE_LIMIT_PER_MINUTE=100

# Environnement
NODE_ENV=development
PYTHON_ENV=development
